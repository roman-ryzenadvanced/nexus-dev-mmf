{
  "name": "nexus-dev-mmf",
  "version": "5.1.0",
  "description": "Multi-Model Fusion Engine (MMFE) — Adaptive multi-model orchestrator with MTP hyperthreading, code review, design skill, Nexus Code TUI, and multi-provider support (ZAI/GLM, OpenAI, Anthropic). Decomposes, routes, executes in parallel, and synthesizes results across any LLM provider.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nexus-dev": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build-verify": "npm run format && npx tsc --noEmit --pretty && npm run lint:fix && npm run build && npm run test",
    "build:nexus-code": "cd packages/nexus-code && npm run build",
    "build:all": "npm run build && npm run build:nexus-code",
    "test": "tsx --test tests/runner.mjs",
    "test:quick": "tsx --test tests/runner.mjs --quick",
    "test:nexus-code": "cd packages/nexus-code && npm test",
    "test:all": "npm test && npm run test:nexus-code",
    "start": "node dist/cli.js",
    "nexus-code": "cd packages/nexus-code && node bin/nexus.js",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "setup": "node scripts/setup.mjs"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "multi-model",
    "orchestrator",
    "fusion",
    "glm",
    "z-ai",
    "openai",
    "anthropic",
    "google",
    "gemini",
    "claude",
    "gpt",
    "parallel-execution",
    "adaptive-routing",
    "design-skill",
    "ai-slope",
    "mtp",
    "code-review",
    "ui-ux",
    "multi-provider",
    "llm-router",
    "tui",
    "cli",
    "terminal",
    "nexus-code",
    "ink",
    "react"
  ],
  "author": "roman-ryzenadvanced",
  "license": "MIT",
  "dependencies": {
    "csv-parse": "^7.0.0",
    "z-ai-web-dev-sdk": "^0.0.18"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.43",
    "typescript": "^5.9.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.0.0",
    "prettier": "3.6.2",
    "tsx": "^4.22.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
